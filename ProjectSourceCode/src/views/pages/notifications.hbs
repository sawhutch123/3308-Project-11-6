{{!< main}}
<div class="container" style="max-width:700px; padding-top:2rem; padding-bottom:5rem;">

  <!-- Page Header -->
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-4">
    <div class="d-flex align-items-center gap-3">
      <div class="page-title-bar"></div>
      <h1 class="page-title mb-0">
        NOTIFICATIONS
        <span class="unread-pill">{{unreadCount}}</span>
      </h1>
    </div>
    <!-- Mark all read submits a POST form, no JavaScript needed -->
    <form action="/notifications/mark-read" method="POST">
      <button type="submit" class="btn-cuff-outline">Mark all read</button>
    </form>
  </div>
  <hr class="mb-4" style="border-color:var(--cuff-border);" />
<ul class="nav filter-nav mb-3">
  <li class="nav-item"><button class="nav-link active" onclick="filterTab(this,'all')">All</button></li>
  <li class="nav-item"><button class="nav-link" onclick="filterTab(this,'rsvp')">RSVPs</button></li>
  <li class="nav-item"><button class="nav-link" onclick="filterTab(this,'friend')">Friends</button></li>
  <li class="nav-item"><button class="nav-link" onclick="filterTab(this,'invite')">Invites</button></li>
  <li class="nav-item"><button class="nav-link" onclick="filterTab(this,'event')">Events</button></li>
</ul>
  <!-- Notification Feed -->
  {{#if notifications.length}}
    <div class="d-flex flex-column gap-2">
      {{#each notifications}}
        <a href="{{#if (eq this.type 'friend')}}/account{{else if this.related_event_id}}/events/{{this.related_event_id}}{{else}}/home{{/if}}" style="text-decoration:none;">
          <div class="notif-card p-3 {{#unless this.is_read}}unread{{/unless}}" data-type="{{this.type}}">
            <div class="d-flex align-items-start gap-3">
              <div class="notif-icon">
                {{#if (eq this.type 'rsvp')}}✅{{/if}}
                {{#if (eq this.type 'friend')}}👋{{/if}}
                {{#if (eq this.type 'invite')}}🔒{{/if}}
                {{#if (eq this.type 'event')}}🎉{{/if}}
              </div>
              <div class="flex-grow-1 overflow-hidden">
                <div class="d-flex justify-content-between align-items-baseline gap-2 mb-1">
                  <span class="notif-title">{{this.message}}</span>
                  <span class="notif-time">{{timeAgo this.created_at}}</span>
                </div>
                <span class="notif-tag tag-{{this.type}}">{{this.type}}</span>
              </div>
              {{#unless this.is_read}}
                <div class="unread-dot"></div>
              {{/unless}}
            </div>
          </div>
        </a>
      {{/each}}
    </div>
  {{else}}
    <div class="empty-state">
      <div class="empty-icon">🔔</div>
      <p>No notifications yet.</p>
    </div>
  {{/if}}

</div>

<!-- Toast -->
<div id="toast-container">
  <div class="cuff-toast" id="cuff-toast"></div>
</div>
<script>
function filterTab(btn, cat) {
    document.querySelectorAll('.filter-nav .nav-link').forEach(t => t.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('.notif-card').forEach(card => {
        if (cat === 'all' || card.dataset.type === cat) {
            card.parentElement.style.display = 'block';
        } else {
            card.parentElement.style.display = 'none';
        }
    });
}
</script>