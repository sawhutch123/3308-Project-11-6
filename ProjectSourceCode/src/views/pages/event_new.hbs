{{!< main}}
<div class="container-fluid" style="max-width:1200px; padding-top:2rem; padding-bottom:5rem;">

  <!-- Page Title -->
  <div class="d-flex align-items-center gap-3 mb-3">
    <div class="page-title-bar"></div>
    <h1 class="page-title mb-0">EVENT CREATION PAGE</h1>
  </div>
  <hr style="border-color:var(--cuff-border); margin-bottom:1.5rem;" />

  {{#if error}}
    <div style="background:#fee2e2; border:1px solid #fca5a5; color:#991b1b;
         font-family:'Space Mono',monospace; font-size:0.75rem; padding:0.75rem 1rem; margin-bottom:1.25rem;">
      {{error}}
    </div>
  {{/if}}

  <form method="POST" action="/events/new" id="create-event-form">
  <div class="row g-4">

    <!-- ── LEFT: FORM STEPS ── -->
    <div class="col-lg-8">

      <!-- STEP 1: EVENT BASICS -->
      <div class="creation-step mb-4">
        <div class="step-header">
          <span class="step-number">1</span>
          <span class="step-title">STEP 1: EVENT BASICS</span>
        </div>
        <div style="padding:1.25rem;">

          <div class="mb-3">
            <label class="creation-label">EVENT NAME</label>
            <input class="cuff-input" type="text" name="event_name" placeholder="e.g. Neon Rave Night 2025"
                   oninput="updatePreview('name', this.value)" required />
          </div>

          <div class="mb-3">
            <label class="creation-label">EVENT DESCRIPTION</label>
            <textarea class="cuff-input" name="event_details" rows="4"
                      placeholder="[ Describe your event: what to expect, dress code, any rules for guests, etc... ]"
                      maxlength="500"
                      oninput="updateCharCount(this); updateChecklist('desc', this.value.length > 0);"></textarea>
            <div style="font-family:'Space Mono',monospace; font-size:0.65rem; color:var(--cuff-gray-light); margin-top:4px;">
              <span id="char-count">0</span> / 500 characters
            </div>
          </div>

          <div class="mb-1">
            <label class="creation-label">EVENT TYPE</label>
          </div>
          <div class="row g-2">
            <div class="col-6">
              <label class="event-type-option selected" id="type-public" onclick="selectType('public', this)">
                <input type="radio" name="event_type" value="public" checked style="display:none;" />
                <span style="font-size:1rem;">🌐</span>
                <div>
                  <div style="font-weight:700; font-size:0.8rem;">PUBLIC</div>
                  <div style="font-size:0.68rem; color:var(--cuff-gray-light);">Visible to all</div>
                </div>
              </label>
            </div>
            <div class="col-6">
              <label class="event-type-option" id="type-private" onclick="selectType('private', this)">
                <input type="radio" name="event_type" value="private" style="display:none;" />
                <span style="font-size:1rem;">🔒</span>
                <div>
                  <div style="font-weight:700; font-size:0.8rem;">PRIVATE</div>
                  <div style="font-size:0.68rem; color:var(--cuff-gray-light);">Friends & invited users only</div>
                </div>
              </label>
            </div>
          </div>
        </div>
      </div>

      <!-- STEP 2: EVENT LOGISTICS -->
      <div class="creation-step mb-4">
        <div class="step-header">
          <span class="step-number">2</span>
          <span class="step-title">STEP 2: EVENT LOGISTICS</span>
        </div>
        <div style="padding:1.25rem;">

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="creation-label">EVENT DATE</label>
              <input class="cuff-input" type="date" name="event_date"
                     oninput="updateChecklist('date', this.value.length > 0); syncDatetime();" required />
            </div>
            <div class="col-md-6">
              <label class="creation-label">START TIME</label>
              <input class="cuff-input" type="time" name="start_time"
                     oninput="syncDatetime();" required />
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="creation-label">END TIME</label>
              <input class="cuff-input" type="time" name="end_time" oninput="syncDatetime();" />
            </div>
            <div class="col-md-6">
              <label class="creation-label">CAPACITY (MAX GUESTS)</label>
              <input class="cuff-input" type="number" name="capacity" min="1" placeholder="e.g. 50"
                     oninput="updateChecklist('capacity', this.value.length > 0)" />
            </div>
          </div>

          <!-- Hidden combined datetime fields for backend -->
          <input type="hidden" name="event_start_time" id="event_start_time_combined" />
          <input type="hidden" name="event_end_time" id="event_end_time_combined" />

          <div class="mb-3">
            <label class="creation-label">VENUE / ADDRESS *</label>
            <input class="cuff-input" type="text" name="venue_address"
                   placeholder="Full address or description..."
                   oninput="updateChecklist('location', this.value.length > 0); updatePreview('location', this.value);" />
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-4">
              <label class="creation-label">STREET *</label>
              <input class="cuff-input" type="text" name="street" placeholder="University Ave" required />
            </div>
            <div class="col-md-4">
              <label class="creation-label">BUILDING # *</label>
              <input class="cuff-input" type="number" name="building_number" placeholder="1234" required />
            </div>
            <div class="col-md-4">
              <label class="creation-label">ZIP *</label>
              <input class="cuff-input" type="number" name="zip_code" placeholder="80302" required />
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="creation-label">ENTRY FEE</label>
              <input class="cuff-input" type="text" name="event_cost" placeholder="e.g. $5 or Free"
                     oninput="updateChecklist('fee', this.value.length > 0); updatePreview('fee', this.value);" />
            </div>
            <div class="col-md-6">
              <label class="creation-label">THEME</label>
              <input class="cuff-input" type="text" name="theme" placeholder="e.g. Neon, Formal, Casual..."
                     oninput="updatePreview('theme', this.value)" />
            </div>
          </div>

          <div class="mb-3">
            <label class="creation-label">PARKING / TRANSIT INFO</label>
            <input class="cuff-input" type="text" name="parking_info" placeholder="e.g. Street parking, no lot..." />
          </div>

          <!-- Calendar display (visual only) -->
          <div class="calendar-box mt-3" id="mini-calendar">
            <div style="font-family:'Space Mono',monospace; font-size:0.65rem; font-weight:700; color:var(--cuff-gray-mid); text-align:center; margin-bottom:0.75rem; letter-spacing:0.1em;">
              [ CALENDAR / DATE PICKER COMPONENT ]
            </div>
            <div id="calendar-grid"></div>
          </div>

          <!-- Map placeholder -->
          <div class="mt-3">
            <div class="creation-label">PIN LOCATION ON MAP</div>
            <div class="map-placeholder" style="height:120px;">
              <i class="bi bi-map" style="font-size:1.5rem; color:var(--cuff-gray-light);"></i>
              <span style="font-family:'Space Mono',monospace; font-size:0.7rem; color:var(--cuff-gray-light); margin-top:4px;">
                [ LOCATION PICKER MAP — DRAG PIN ]
              </span>
            </div>
            <div style="font-family:'Space Mono',monospace; font-size:0.65rem; color:var(--cuff-gray-light); margin-top:4px; font-style:italic;">
              [ Drag pin to set exact location for guests ]
            </div>
          </div>
        </div>
      </div>

      <!-- STEP 3: EVENT PHOTO & MEDIA -->
      <div class="creation-step mb-4">
        <div class="step-header">
          <span class="step-number">3</span>
          <span class="step-title">STEP 3: EVENT PHOTO & MEDIA</span>
        </div>
        <div style="padding:1.25rem;">
          <div class="photo-upload-zone" onclick="document.getElementById('cover-upload').click()">
            <i class="bi bi-camera" style="font-size:1.75rem; color:var(--cuff-gray-mid);"></i>
            <div style="font-family:'Space Mono',monospace; font-size:0.75rem; font-weight:700; color:var(--cuff-gray-dark); margin-top:0.5rem;">EVENT COVER PHOTO</div>
            <div style="font-family:'Space Mono',monospace; font-size:0.68rem; color:var(--cuff-gray-light); margin-top:4px;">[ Drag & drop or click to upload event banner photo ]</div>
            <div style="font-family:'Space Mono',monospace; font-size:0.65rem; color:var(--cuff-gray-light); margin-top:2px;">Recommended: 1200 × 628px · JPG or PNG · Max 5MB</div>
            <button type="button" class="btn-cuff-outline" style="margin-top:0.75rem; font-size:0.7rem;">[ UPLOAD PHOTO ]</button>
            <input type="file" id="cover-upload" name="cover_photo" accept="image/*" style="display:none;"
                   onchange="updateChecklist('photo', true)" />
          </div>

          <div class="row g-2 mt-3">
            <div class="col-4">
              <div class="additional-photo-box">+ Add photo 1</div>
            </div>
            <div class="col-4">
              <div class="additional-photo-box">+ Add photo 2</div>
            </div>
            <div class="col-4">
              <div class="additional-photo-box">+ Add photo 3</div>
            </div>
          </div>
          <div style="font-family:'Space Mono',monospace; font-size:0.65rem; color:var(--cuff-gray-light); margin-top:6px; font-style:italic;">
            [ Optional: Add additional event photos ]
          </div>
        </div>
      </div>

      <!-- STEP 4: PRIVACY & GUEST ACCESS -->
      <div class="creation-step mb-4">
        <div class="step-header">
          <span class="step-number">4</span>
          <span class="step-title">STEP 4: PRIVACY & GUEST ACCESS</span>
        </div>
        <div style="padding:1.25rem;">
          <div class="mb-4">
            <div class="creation-label">GUEST APPROVAL</div>
            <div class="d-flex flex-column gap-2 mt-2">
              <label class="filter-radio-label">
                <input type="radio" name="guest_approval" value="auto" checked /> Auto-approve all RSVPs
              </label>
              <label class="filter-radio-label">
                <input type="radio" name="guest_approval" value="manual" /> Manually approve each RSVP request
              </label>
            </div>
          </div>

          <div>
            <div class="creation-label">INVITE SPECIFIC USERS</div>
            <div style="position:relative; margin-top:0.4rem;">
              <i class="bi bi-search" style="position:absolute; left:0.75rem; top:50%; transform:translateY(-50%); color:var(--cuff-gray-light); font-size:0.8rem;"></i>
              <input class="cuff-input" type="text" id="invite-search" style="padding-left:2.25rem;"
                     placeholder="Search CU students to invite..." />
            </div>
            <div class="d-flex flex-wrap gap-2 mt-2" id="invited-tags">
              <!-- Invite tags populated by JS -->
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- ── RIGHT SIDEBAR ── -->
    <div class="col-lg-4">
      <div style="position:sticky; top:72px;">

        <!-- Live Preview -->
        <div class="cuff-section mb-3">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <div class="cuff-section-title mb-0" style="border-bottom:none; padding-bottom:0;">LIVE PREVIEW</div>
            <span style="font-family:'Space Mono',monospace; font-size:0.65rem; color:var(--cuff-gray-light); font-style:italic;">(what others see)</span>
          </div>
          <hr style="border-color:var(--cuff-border); margin-bottom:0.75rem;" />

          <div class="preview-banner">
            <span style="font-family:'Space Mono',monospace; font-size:0.65rem; color:var(--cuff-gray-light);">[ EVENT COVER PHOTO ]</span>
          </div>
          <div style="padding:0.75rem; border:1px solid var(--cuff-border); border-top:none; background:var(--cuff-white);">
            <span class="search-public-tag" style="font-size:0.6rem; margin-bottom:6px; display:inline-block;">PUBLIC</span>
            <div style="font-family:'Space Mono',monospace; font-size:0.82rem; font-weight:700; margin-bottom:6px;" id="preview-name">
              [ Event Name Here ]
            </div>
            <div style="font-family:'Space Mono',monospace; font-size:0.68rem; color:var(--cuff-muted); display:flex; flex-direction:column; gap:3px;">
              <div>📅 <span id="preview-date">[ Date & Time ]</span></div>
              <div>📍 <span id="preview-location">[ Location ]</span></div>
              <div>🔥 <span id="preview-fee">[ Entry Fee ]</span> · 🎨 <span id="preview-theme">[ Theme ]</span></div>
              <div>👤 Hosted by You</div>
            </div>
          </div>
        </div>

        <!-- Completion Checklist -->
        <div class="cuff-section mb-3">
          <div class="cuff-section-title">COMPLETION CHECKLIST</div>
          <div class="d-flex flex-column gap-2">
            <label class="checklist-item" id="check-name">
              <span class="check-box" id="cb-name">☐</span> Event name
            </label>
            <label class="checklist-item" id="check-desc">
              <span class="check-box" id="cb-desc">☐</span> Description
            </label>
            <label class="checklist-item" id="check-date">
              <span class="check-box" id="cb-date">☐</span> Date & time
            </label>
            <label class="checklist-item" id="check-location">
              <span class="check-box" id="cb-location">☐</span> Location / address
            </label>
            <label class="checklist-item" id="check-fee">
              <span class="check-box" id="cb-fee">☐</span> Entry fee
            </label>
            <label class="checklist-item" id="check-photo">
              <span class="check-box" id="cb-photo">☐</span> Cover photo
            </label>
            <label class="checklist-item checked" id="check-privacy">
              <span class="check-box checked-box" id="cb-privacy">✓</span> Privacy settings
            </label>
            <label class="checklist-item" id="check-capacity">
              <span class="check-box" id="cb-capacity">☐</span> Guest capacity
            </label>
          </div>
          <div style="margin-top:0.75rem;">
            <div style="font-family:'Space Mono',monospace; font-size:0.68rem; color:var(--cuff-muted); margin-bottom:4px;">
              <span id="complete-count">1</span> of 8 fields complete
            </div>
            <div style="background:var(--cuff-border); height:6px; width:100%;">
              <div id="progress-bar" style="background:var(--cuff-navy); height:6px; width:12.5%; transition:width 0.3s;"></div>
            </div>
          </div>
        </div>

        <!-- Save & Publish -->
        <div class="cuff-section">
          <div class="cuff-section-title">SAVE & PUBLISH</div>
          <div class="d-flex flex-column gap-2">
            <button type="submit" name="action" value="publish" class="btn-cuff-action" style="font-size:0.75rem;">
              [ PUBLISH EVENT ]
            </button>
            <button type="submit" name="action" value="draft" class="btn-cuff-outline" style="font-size:0.72rem;">
              [ SAVE AS DRAFT ]
            </button>
            <button type="button" class="btn-cuff-outline" style="font-size:0.72rem;">
              [ PREVIEW EVENT PAGE ]
            </button>
            <a href="/home" class="btn-cuff-outline" style="font-size:0.72rem; text-align:center; text-decoration:none; display:block; padding:0.35rem 0.9rem;">
              [ DISCARD & CANCEL ]
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>
  </form>
</div>

<style>
  .creation-step {
    border: 1px solid var(--cuff-border);
    background: var(--cuff-white);
  }

  .step-header {
    background: var(--cuff-surface);
    border-bottom: 1px solid var(--cuff-border);
    padding: 0.75rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .step-number {
    width: 24px;
    height: 24px;
    background: var(--cuff-navy);
    color: #fff;
    font-family: 'Space Mono', monospace;
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .step-title {
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--cuff-text);
  }

  .creation-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--cuff-gray-dark);
    display: block;
    margin-bottom: 0.4rem;
  }

  .event-type-option {
    border: 2px solid var(--cuff-border);
    background: var(--cuff-white);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    cursor: pointer;
    font-family: 'Space Mono', monospace;
    transition: all 0.15s;
    width: 100%;
  }

  .event-type-option.selected {
    background: var(--cuff-navy);
    border-color: var(--cuff-navy);
    color: #fff;
  }

  .event-type-option.selected div {
    color: #fff !important;
  }

  .calendar-box {
    border: 1px dashed var(--cuff-border);
    padding: 1rem;
    background: var(--cuff-surface);
  }

  .cal-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin-bottom: 2px;
  }

  .cal-cell {
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    text-align: center;
    padding: 4px 2px;
    color: var(--cuff-text);
    cursor: pointer;
    border-radius: 0;
  }

  .cal-cell:hover {
    background: var(--cuff-border);
  }

  .cal-cell.today {
    background: var(--cuff-navy);
    color: #fff;
    font-weight: 700;
  }

  .cal-cell.header {
    font-weight: 700;
    color: var(--cuff-gray-mid);
    cursor: default;
    font-size: 0.62rem;
  }

  .cal-cell.empty {
    cursor: default;
  }

  .map-placeholder {
    width: 100%;
    background: #e5e7eb;
    border: 1px solid var(--cuff-border);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .photo-upload-zone {
    border: 2px dashed var(--cuff-border);
    padding: 2rem 1rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    cursor: pointer;
    transition: border-color 0.15s;
    background: var(--cuff-surface);
  }

  .photo-upload-zone:hover {
    border-color: var(--cuff-navy);
  }

  .additional-photo-box {
    border: 1px dashed var(--cuff-border);
    height: 90px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    color: var(--cuff-gray-light);
    cursor: pointer;
    background: var(--cuff-surface);
    transition: border-color 0.15s;
  }

  .additional-photo-box:hover {
    border-color: var(--cuff-gray-mid);
  }

  .filter-radio-label {
    font-family: 'Space Mono', monospace;
    font-size: 0.75rem;
    color: var(--cuff-text);
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
  }

  .filter-radio-label input {
    accent-color: var(--cuff-navy);
  }

  .preview-banner {
    width: 100%;
    height: 100px;
    background: #e5e7eb;
    border: 1px solid var(--cuff-border);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .checklist-item {
    font-family: 'Space Mono', monospace;
    font-size: 0.72rem;
    color: var(--cuff-muted);
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: default;
  }

  .checklist-item.checked {
    color: var(--cuff-text);
    font-weight: 700;
  }

  .check-box {
    font-size: 0.8rem;
    color: var(--cuff-border);
    flex-shrink: 0;
  }

  .checked-box {
    color: #065f46 !important;
    font-weight: 700;
  }

  .invite-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.68rem;
    padding: 3px 8px;
    background: var(--cuff-navy);
    color: #fff;
    display: flex;
    align-items: center;
    gap: 6px;
    border-radius: 0;
  }

  .invite-tag button {
    background: none;
    border: none;
    color: #9ca3af;
    cursor: pointer;
    font-size: 0.75rem;
    padding: 0;
    line-height: 1;
  }

  .search-public-tag {
    font-family: 'Space Mono', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    padding: 2px 7px;
    border: 1px solid var(--cuff-border);
    color: var(--cuff-gray-dark);
    letter-spacing: 0.04em;
  }
</style>

<script>
  // ── Checklist state ──────────────────────────────────────────────────────────
  const checks = { name: false, desc: false, date: false, location: false, fee: false, photo: false, privacy: true, capacity: false };

  function updateChecklist(key, val) {
    checks[key] = !!val;
    const cb = document.getElementById('cb-' + key);
    const item = document.getElementById('check-' + key);
    if (cb) { cb.textContent = val ? '✓' : '☐'; cb.className = val ? 'check-box checked-box' : 'check-box'; }
    if (item) item.className = val ? 'checklist-item checked' : 'checklist-item';
    const total = Object.values(checks).filter(Boolean).length;
    document.getElementById('complete-count').textContent = total;
    document.getElementById('progress-bar').style.width = (total / 8 * 100) + '%';
  }

  // ── Live preview updates ─────────────────────────────────────────────────────
  function updatePreview(field, val) {
    const map = { name: 'preview-name', location: 'preview-location', fee: 'preview-fee', theme: 'preview-theme' };
    const defaults = { name: '[ Event Name Here ]', location: '[ Location ]', fee: '[ Entry Fee ]', theme: '[ Theme ]' };
    const el = document.getElementById(map[field]);
    if (el) el.textContent = val || defaults[field];
    if (field === 'name') updateChecklist('name', val.length > 0);
  }

  function syncDatetime() {
    const date = document.querySelector('[name=event_date]')?.value;
    const time = document.querySelector('[name=start_time]')?.value;
    const endTime = document.querySelector('[name=end_time]')?.value;
    if (date && time) {
      document.getElementById('event_start_time_combined').value = date + 'T' + time;
      document.getElementById('preview-date').textContent = date + ' at ' + time;
      updateChecklist('date', true);
    }
    if (date && endTime) {
      document.getElementById('event_end_time_combined').value = date + 'T' + endTime;
    }
  }

  function updateCharCount(el) {
    document.getElementById('char-count').textContent = el.value.length;
    updateChecklist('desc', el.value.length > 0);
  }

  // ── Event type selector ──────────────────────────────────────────────────────
  function selectType(type, el) {
    document.getElementById('type-public').classList.remove('selected');
    document.getElementById('type-private').classList.remove('selected');
    el.classList.add('selected');
    el.querySelector('input[type=radio]').checked = true;
  }

  // ── Mini calendar ────────────────────────────────────────────────────────────
  function renderCalendar() {
    const grid = document.getElementById('calendar-grid');
    if (!grid) return;
    const now = new Date();
    const year = now.getFullYear(), month = now.getMonth();
    const firstDay = new Date(year, month, 1).getDay();
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const days = ['S','M','T','W','T','F','S'];

    let html = '<div class="cal-row">' + days.map(d => `<div class="cal-cell header">${d}</div>`).join('') + '</div>';
    let cells = '<div class="cal-row">';
    for (let i = 0; i < firstDay; i++) cells += '<div class="cal-cell empty"></div>';
    for (let d = 1; d <= daysInMonth; d++) {
      if ((firstDay + d - 1) % 7 === 0 && d > 1) cells += '</div><div class="cal-row">';
      const isToday = d === now.getDate();
      cells += `<div class="cal-cell ${isToday ? 'today' : ''}" onclick="pickDay(${year},${month+1},${d})">${d}</div>`;
    }
    cells += '</div>';
    grid.innerHTML = html + cells;
  }

  function pickDay(y, m, d) {
    const dateStr = `${y}-${String(m).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const dateInput = document.querySelector('[name=event_date]');
    if (dateInput) { dateInput.value = dateStr; syncDatetime(); }
  }

  // ── Invite tags ──────────────────────────────────────────────────────────────
  document.addEventListener('DOMContentLoaded', () => {
    renderCalendar();
    const inviteInput = document.getElementById('invite-search');
    if (inviteInput) {
      inviteInput.addEventListener('keydown', e => {
        if (e.key === 'Enter') {
          e.preventDefault();
          const name = inviteInput.value.trim();
          if (!name) return;
          const tag = document.createElement('div');
          tag.className = 'invite-tag';
          tag.innerHTML = `${name} <button type="button" onclick="this.parentElement.remove()">×</button>`;
          document.getElementById('invited-tags').appendChild(tag);
          inviteInput.value = '';
        }
      });
    }
  });
</script>
